.progress{
    width:100%;
    height:10px;
    background:#3a3a3a;
    border-radius:10px;
    margin-top:25px;
    overflow:hidden;
}

.bar{
    width:0%;
    height:100%;
    background:#4c8bf5;
    animation:load 10s linear forwards;
}

@keyframes load{
    from{width:0%;}
    to{width:100%;}
}

.status{
    margin-top:18px;
    font-size:15px;
    color:#9aa0a6;
}

