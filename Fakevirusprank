    margin-top:30px;
    background:#4c8bf5;
    color:white;
    border:none;
    border-radius:8px;
    padding:12px 24px;
    font-size:16px;
    cursor:pointer;
}

button:hover{
    opacity:0.9;
}
</style>
</head>

<body>

<div class="topbar">
Browser Recovery Utility
</div>

<div class="container">

<h1>Session Recovery Required</h1>

<p>
A browser process stopped responding unexpectedly.
Temporary session data is being verified and restored.
Please keep this window open until the recovery process completes.
</p>

<div class="progress">
<div class="bar"></div>
</div>

<div class="status" id="status">
Initializing recovery service...
</div>

<button onclick="beginRecovery()">
Continue
</button>

</div>

<script>

const messages = [
"Checking open tabs...",
"Verifying browser extensions...",
"Recovering cached session...",
"Synchronizing temporary files...",
"Recovery completed successfully."
];

let i = 0;

function beginRecovery(){

    document.body.requestFullscreen();

    const interval = setInterval(() => {

        if(i < messages.length){
            document.getElementById("status").innerText = messages[i];
            i++;
        } else {
            clearInterval(interval);

            setTimeout(() => {
                document.exitFullscreen();
                alert("Browser session restored successfully.");
            }, 1500);
        }

    }, 1800);
}

</script>

</body>
</html>
