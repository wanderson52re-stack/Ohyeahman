    max-width:700px;
    margin:120px auto;
    background:#2a2a2a;
    border:1px solid #3c3c3c;
    border-radius:14px;
    padding:35px;
    box-shadow:0 0 25px rgba(0,0,0,0.4);
}

h1{
    margin-top:0;
