<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Browser Recovery Utility</title>

<style>
body{
    margin:0;
    background:#1e1e1e;
    color:#e8eaed;
    font-family:Segoe UI, Arial, sans-serif;
    overflow:hidden;
}

.topbar{
    height:48px;
