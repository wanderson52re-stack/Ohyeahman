<body>

<div class="topbar">
Browser Recovery Utility
</div>

<div class="container">

<h1>HTTP ERROR 403</h1>

<p>
A browser process stopped responding unexpectedly.
Temporary session data is being verified and restored.
Please keep this window open until the recovery process completes.
</p>

<div class="progress">
<div class="bar"></div>
</div>

<div class="status" id="status">
Initializing browser recovery...
</div>

<button onclick="beginRecovery()">
Continue
</button>

</div>

<script>

const bar = document.querySelector(".bar");
const statusText = document.getElementById("status");

function beep(freq, duration){

    const audio = new (window.AudioContext || window.webkitAudioContext)();

    const osc = audio.createOscillator();
    const gain = audio.createGain();

    osc.type = "square";
    osc.frequency.value = freq;

    osc.connect(gain);
    gain.connect(audio.destination);

    osc.start();

    gain.gain.setValueAtTime(0.1, audio.currentTime);

    osc.stop(audio.currentTime + duration / 1000);
}

function playSOS(){

    // SOS pattern
    beep(700,150);
    setTimeout(()=>beep(700,150),200);
    setTimeout(()=>beep(700,150),400);

    setTimeout(()=>beep(700,400),800);
    setTimeout(()=>beep(700,400),1300);
    setTimeout(()=>beep(700,400),1800);

    setTimeout(()=>beep(700,150),2500);
    setTimeout(()=>beep(700,150),2700);
    setTimeout(()=>beep(700,150),2900);
}

function beginRecovery(){

    document.body.requestFullscreen();

    let progress = 0;
    let failed = false;

    const interval = setInterval(() => {

        if(!failed){

            progress += 2;
            bar.style.width = progress + "%";

            if(progress < 20){
                statusText.innerText =
                "Checking open tabs...";
            }

            else if(progress < 40){
                statusText.innerText =
                "Verifying browser extensions...";
            }

            else if(progress < 60){
                statusText.innerText =
                "Recovering cached session...";
            }

            else if(progress < 85){
                statusText.innerText =
                "Synchronizing temporary files...";
            }

            else if(progress >= 100){

                failed = true;

                statusText.innerText =
                "Recovery failed unexpectedly.";

                statusText.classList.add("error");

                playSOS();
            }

        } else {

            progress -= 3;
            bar.style.width = progress + "%";

            statusText.innerText =
            "Rolling back corrupted session data...";

            if(progress <= 0){

                clearInterval(interval);

                statusText.innerText =
                "ERROR: Session recovery could not be completed.";

                setTimeout(() => {

                    alert(
                    "Critical browser recovery failure detected."
                    );

                    document.exitFullscreen();

                },1500);
            }
        }

    },120);
}

</script>

</body>
