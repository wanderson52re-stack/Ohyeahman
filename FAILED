const bar = document.querySelector(".bar");
const statusText = document.getElementById("status");

function beginRecovery(){

    document.body.requestFullscreen();

    let progress = 0;
    let failed = false;

    const interval = setInterval(() => {

        if(!failed){

            progress += 2;
            bar.style.width = progress + "%";

            if(progress < 20){
                statusText.innerText = "Checking open tabs...";
            }
            else if(progress < 40){
                statusText.innerText = "Verifying browser extensions...";
            }
            else if(progress < 60){
                statusText.innerText = "Recovering cached session...";
            }
            else if(progress < 85){
                statusText.innerText = "Synchronizing temporary files...";
            }
            else if(progress >= 100){

                failed = true;
                statusText.innerText = "Recovery failed unexpectedly.";

            }

        } else {

            progress -= 3;
            bar.style.width = progress + "%";

            statusText.innerText =
            "Rolling back corrupted session data...";

            if(progress <= 0){

                clearInterval(interval);

                statusText.innerText =
                "ERROR: Session recovery could not be completed.";

                setTimeout(() => {
                    alert("Recovery process failed.");
                    document.exitFullscreen();
                }, 1500);
            }
        }

    }, 120);

}
